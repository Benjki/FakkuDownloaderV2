# Authentication
FAKKU_USERNAME=
FAKKU_PASSWORD=
FAKKU_TOTP_SECRET=       # Base32 seed from Authenticator app

# Download queue
FAKKU_COLLECTION_URL=    # e.g. https://www.fakku.net/users/<user>/collections/to-dwnl

# Notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Storage
STORAGE_PRIMARY=./downloaded

# Tracking & state files
DONE_FILE=./done.txt
COOKIES_FILE=./cookies.pickle
TEMP_DIR=./tmp

# Tuning
PAGE_TIMEOUT=15
PAGE_WAIT=5
MIN_IMAGE_SIZE_KB=50
MAX_RETRY=3
CHROME_OFFSET=           # px offset for window resize; leave blank to auto-detect
