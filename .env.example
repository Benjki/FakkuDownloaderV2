# Authentication
FAKKU_USERNAME=
FAKKU_PASSWORD=
# Base32 seed from your Authenticator app
FAKKU_TOTP_SECRET=

# Download queue
# e.g. https://www.fakku.net/users/<user>/collections/to-dwnl
FAKKU_COLLECTION_URL=

# Notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Storage
STORAGE_PRIMARY=./downloaded

# Tracking & state files
DONE_FILE=./done.txt
COOKIES_FILE=./cookies.pickle
TEMP_DIR=./tmp

# Tuning
PAGE_TIMEOUT=15
# seconds to wait after each page screenshot (reduce = faster but higher ban risk)
PAGE_WAIT=5
# seconds to pause between books (reduce = faster but higher ban risk)
BOOK_WAIT=30
MIN_IMAGE_SIZE_KB=50
# Comma-separated list of accepted WxH dimensions; leave blank to accept any size
# e.g. ALLOWED_IMAGE_DIMENSIONS=1360x1920,1280x1800
ALLOWED_IMAGE_DIMENSIONS=
MAX_RETRY=3
# px offset for window resize; leave blank to auto-detect
CHROME_OFFSET=
